{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JobPosition",
  "description": "岗位信息数据结构",
  "type": "object",
  "required": [
    "id",
    "title",
    "company",
    "location",
    "job_type",
    "posted_date",
    "source",
    "url"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "岗位唯一标识",
      "pattern": "^[A-Z0-9]{10,}$"
    },
    "title": {
      "type": "string",
      "description": "岗位标题",
      "minLength": 2,
      "maxLength": 100
    },
    "company": {
      "type": "string",
      "description": "公司名称",
      "minLength": 1,
      "maxLength": 100
    },
    "company_size": {
      "type": "string",
      "description": "公司规模",
      "enum": ["少于15人", "15-50人", "50-150人", "150-500人", "500-2000人", "2000人以上"]
    },
    "company_industry": {
      "type": "string",
      "description": "公司行业"
    },
    "location": {
      "type": "string",
      "description": "工作地点",
      "minLength": 2,
      "maxLength": 50
    },
    "job_type": {
      "type": "string",
      "description": "岗位类型",
      "enum": ["全职", "兼职", "实习", "校招"]
    },
    "salary_min": {
      "type": "number",
      "description": "最低薪资（元/月）",
      "minimum": 0
    },
    "salary_max": {
      "type": "number",
      "description": "最高薪资（元/月）",
      "minimum": 0
    },
    "salary_months": {
      "type": "integer",
      "description": "薪资月数",
      "minimum": 12,
      "maximum": 24
    },
    "education": {
      "type": "string",
      "description": "学历要求",
      "enum": ["不限", "高中", "大专", "本科", "硕士", "博士"]
    },
    "experience": {
      "type": "string",
      "description": "经验要求",
      "enum": ["不限", "应届生", "1年以内", "1-3年", "3-5年", "5-10年", "10年以上"]
    },
    "description": {
      "type": "string",
      "description": "岗位描述",
      "maxLength": 10000
    },
    "requirements": {
      "type": "array",
      "description": "岗位要求列表",
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "type": "array",
      "description": "技能标签",
      "items": {
        "type": "string"
      }
    },
    "posted_date": {
      "type": "string",
      "format": "date",
      "description": "发布日期"
    },
    "deadline": {
      "type": "string",
      "format": "date",
      "description": "截止日期"
    },
    "source": {
      "type": "string",
      "description": "来源平台",
      "enum": ["boss", "zhaopin", "51job", "liepin", "other"]
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "原始链接"
    },
    "status": {
      "type": "string",
      "description": "岗位状态",
      "enum": ["active", "closed", "expired"],
      "default": "active"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "数据创建时间"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "数据更新时间"
    }
  }
}
