# ========================================
# 学生求职AI助手 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ========================================

# -------------------
# 应用基础配置
# -------------------
APP_NAME="Internship Assistant API"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# -------------------
# 数据库配置
# 开发环境默认使用 SQLite（data/db/internship.db）
# 生产环境可切换为 MySQL
# -------------------
DATABASE_URL="sqlite:///./data/db/internship.db"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# -------------------
# Redis 配置
# 开发环境可使用内存缓存（redis_url 留空或设为 redis://localhost:6379/0）
# -------------------
REDIS_URL="redis://localhost:6379/0"
REDIS_POOL_SIZE=10

# -------------------
# 安全配置
# -------------------
SECRET_KEY="your-secret-key-change-this-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT 配置（用于认证）
JWT_SECRET_KEY="your-jwt-secret-key-change-this"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# -------------------
# CORS 配置
# 多个来源用英文逗号分隔
# -------------------
CORS_ORIGINS="http://localhost:5173,http://localhost:3000,http://localhost:8080"

# -------------------
# 爬虫配置
# -------------------
CRAWLER_DELAY_MIN=1.0
CRAWLER_DELAY_MAX=5.0
CRAWLER_MAX_RETRIES=3
CRAWLER_TIMEOUT=30
USE_PROXY=false
PROXY_LIST=""

# -------------------
# OpenAI / LLM 配置
# -------------------
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# Anthropic 配置（可选）
ANTHROPIC_API_KEY=""

# -------------------
# 文件存储配置
# -------------------
STORAGE_TYPE=local
STORAGE_LOCAL_PATH="./data/uploads"
STORAGE_MAX_FILE_SIZE=10485760

# -------------------
# 限流配置
# -------------------
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# -------------------
# 监控与日志（可选）
# -------------------
PROMETHEUS_METRICS_ENABLED=false
SENTRY_DSN=""
