# Production Environment Variables Template
# Copy this file to .env.prod and fill in the values

# ====================
# Database Configuration
# ====================
MYSQL_ROOT_PASSWORD=strong_root_password_here
MYSQL_PASSWORD=strong_internship_password_here

# ====================
# Redis Configuration
# ====================
REDIS_PASSWORD=strong_redis_password_here

# ====================
# API Keys (LLM Services)
# ====================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ====================
# Application Settings
# ====================
SECRET_KEY=generate_a_secure_random_secret_key_here
ENVIRONMENT=production
LOG_LEVEL=INFO

# ====================
# Security Settings
# ====================
# CORS origins (comma-separated)
ALLOWED_ORIGINS=https://internship.example.com

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ====================
# Monitoring
# ====================
# Sentry DSN (optional)
SENTRY_DSN=your_sentry_dsn_here

# Prometheus (if enabled)
PROMETHEUS_METRICS_PORT=9090

# ====================
# External Services
# ====================
# Email service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ====================
# Deployment Settings
# ====================
# Docker image tags
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# Health check settings
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_RETRIES=3