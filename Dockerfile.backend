# Dockerfile.backend - Backend Docker configuration template
# This file is a template for the backend Docker setup.
# The actual Dockerfile used in docker-compose is at ./backend/Dockerfile

# Base image
FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    libpq-dev \
    curl \
    gnupg \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements file
COPY ./backend/requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend source code
COPY ./backend/ .

# Create non-root user for security
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Expose application port
EXPOSE 8000

# Default command (can be overridden in docker-compose)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]

# Environment variables example (set in docker-compose or .env):
# - DATABASE_URL: Database connection string
# - REDIS_URL: Redis connection string
# - SECRET_KEY: Application secret key
# - OPENAI_API_KEY: OpenAI API key
# - DEBUG: Debug mode (True/False)