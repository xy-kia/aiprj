# Production Environment Variables Template
# Copy this file to .env.prod and fill in the actual values
# Never commit actual secrets to version control!

# ====================
# Database Configuration
# ====================
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=mysql+pymysql://internship:${MYSQL_PASSWORD}@mysql:3306/internship_db

# ====================
# Redis Configuration
# ====================
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ====================
# API Keys & External Services
# ====================
OPENAI_API_KEY=CHANGE_ME_YOUR_OPENAI_API_KEY
ANTHROPIC_API_KEY=CHANGE_ME_YOUR_ANTHROPIC_API_KEY

# ====================
# Application Settings
# ====================
SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_SECRET_KEY
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false

# ====================
# Crawler Configuration
# ====================
CRAWLER_DELAY_MIN=2
CRAWLER_DELAY_MAX=5
CRAWLER_MAX_RETRIES=3
USE_PROXY=false
PROXY_URL=

# ====================
# Security & Rate Limiting
# ====================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ====================
# Monitoring & Observability
# ====================
PROMETHEUS_METRICS_ENABLED=true
SENTRY_DSN=
LOGGING_FORMAT=json

# ====================
# Frontend Configuration
# ====================
VITE_API_BASE_URL=/api
VITE_APP_TITLE=Internship AI Assistant