# Auto detect text files and perform LF normalization
* text=auto

# Windows batch files should have CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts should have LF line endings
*.sh text eol=lf

# Python files
*.py text eol=lf

# JavaScript/TypeScript files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
